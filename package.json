{
  "name": "omi-portal-core",
  "version": "0.2.0",
  "description": "Monolithic OMI Portal — POS graph, WordNet centroid, JAB Code, Hopf fibration, octonionic Fano, Code 16K, and tri-clamped sphere packing kernels.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "node --test test/*.test.js",
    "demo": "node examples/node-demo.js",
    "bundle:wink-browserify": "browserify examples/browserify-entry.cjs -o public/wink-bundle.js",
    "demo:wordnet": "node examples/wordnet-demo.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@vitejs/plugin-react": "^5.0.0",
    "aframe": "^1.7.1",
    "aframe-environment-component": "^1.5.0",
    "codemirror": "^6.0.2",
    "tinyneat": "^1.1.0",
    "vite": "^6.0.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "wordpos": "^2.1.0",
    "wordpos-web": "^1.0.2"
  },
  "devDependencies": {
    "browserify": "^17.0.1",
    "playwright": "^1.60.0",
    "terser": "^5.48.0"
  },
  "keywords": [
    "omi",
    "pos-tags",
    "winknlp",
    "tinyneat",
    "json-canvas",
    "scgnn",
    "sharedarraybuffer",
    "wordnet",
    "wordpos-web",
    "dom",
    "cssom",
    "cidr"
  ]
}
