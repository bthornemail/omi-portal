{
  "name": "omi-pos-scgnn-tinyneat",
  "version": "0.2.0",
  "description": "POS and WordNet synset centroid feature tokens for a default chiral SCGNN node policy using winkNLP, wordpos-web, and TinyNEAT.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "node --test test/*.test.js",
    "demo": "node examples/node-demo.js",
    "bundle:wink-browserify": "browserify examples/browserify-entry.cjs -o public/wink-bundle.js",
    "demo:wordnet": "node examples/wordnet-demo.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^6.0.0",
    "wink-nlp": "^2.4.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "tinyneat": "^0.4.0",
    "wordpos-web": "^1.0.2",
    "wordpos": "^2.1.0"
  },
  "devDependencies": {
    "browserify": "^17.0.1"
  },
  "keywords": [
    "omi",
    "pos-tags",
    "winknlp",
    "tinyneat",
    "json-canvas",
    "scgnn",
    "sharedarraybuffer",
    "wordnet",
    "wordpos-web",
    "dom",
    "cssom",
    "cidr"
  ]
}
