      "entries": ["Mood", "Tense", "Person", "Number", "PronType", "Case", "Gender", "VerbForm"]
    },
    {
      "id": "wordnet-operators",
      "role": "Prolog WordNet synset relation routing",
      "entries": ["s", "sk", "g", "syntax", "hyp", "ins", "ent", "sim", "mm", "ms", "mp", "der", "cls", "cs", "vgp", "at", "ant", "sa", "ppl", "per", "fr"]
    }
