    { "term": "RS", "definition": "Control predicate segment bounded to 0x00..0x3f." },
    { "term": "US", "definition": "Unit/codepoint segment bounded to 0x00..0x7f." },
    { "term": "DataView", "definition": "Byte-level memory interpretation layer for OMI buffers and packets." }
