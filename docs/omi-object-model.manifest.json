  "polynomial": {
    "id": "four-term-characteristic-polynomial",
    "status": "implemented-partial",
    "equation": "P(t)=cFS*t^3+cGS*t^2+cRS*t+cUS",
    "evaluation": "horners-method",
    "payloadBytes": 16,
    "coefficients": [
      { "byteOffset": "0..3", "index": 0, "term": "FS_Weight" },
      { "byteOffset": "4..7", "index": 1, "term": "GS_Weight" },
      { "byteOffset": "8..11", "index": 2, "term": "RS_Weight" },
      { "byteOffset": "12..15", "index": 3, "term": "US_Weight" }
    ],
    "glsl": "((aCoefficients.x * uTimeStep + aCoefficients.y) * uTimeStep + aCoefficients.z) * uTimeStep + aCoefficients.w"
  },
