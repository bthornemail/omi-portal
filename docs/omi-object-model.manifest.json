    {
      "id": "upos-port-projection",
      "role": "Universal POS to OMI port channel projection",
      "entries": [
        { "key": "FS", "class": "open-content", "tags": ["NOUN", "PROPN", "VERB", "ADJ"], "role": "base entities, actions, global script blocks, and process boundaries" },
        { "key": "GS", "class": "closed-operator", "tags": ["ADP", "AUX", "CCONJ", "NUM", "DET", "PART"], "role": "loop counts, bitwidth shifts, carry signals, and coordinate scalars" },
        { "key": "RS", "class": "linguistic-predicate", "tags": ["ADV", "INTJ", "PRON", "SCONJ"], "role": "0x00..0x3f controls and lazy Prolog F-expression declarations" },
        { "key": "US", "class": "volatile-unit", "tags": ["PUNCT", "SYM", "X"], "role": "0x00..0x7f codepoints, eager S-expression leaves, and terminal polynomial payloads" }
      ]
    },
    {
      "id": "universal-features",
