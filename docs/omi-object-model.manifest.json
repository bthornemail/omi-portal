  "terms": [
    { "term": "OMI", "definition": "Hyphen-delimited object identity and route token namespace." },
    { "term": "CIDR", "definition": "Containment and stability model for address prefix projection." },
    { "term": "IPR", "definition": "IP routing / route-table semantics over OMI token prefixes." },
    { "term": "DOM", "definition": "Runtime browser object tree and address host." },
    { "term": "CSSOM", "definition": "Native selector and rule surface for OMI prefix routing." },
