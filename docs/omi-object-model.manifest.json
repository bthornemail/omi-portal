      },
      "cdr": {
        "encoding": "utf-8 printable text",
        "delimiter": ".",
        "shape": "content.context.payload",
        "content": "omi-* route",
        "context": "hyphen-delimited UPOS ports",
        "payload": "URL-safe Base64 typed vector or UTF-8 clamped fallback",
        "lambdaCube": [
          "content CIDR block space hierarchy",
          "context UPOS port socket pair",
          "Base64 Float32 vector payload"
        ]
