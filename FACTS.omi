# ============================================================================
# OMICRON OBJECT MODEL (OMI) - UNIVERSAL FACT DEFINITIONS
# File Target: /FACTS.omi
# Specification Level: Universal POS & Feature Token Matrix
# ============================================================================
#
# This file declares factual assignments for language-agnostic data
# processing. Universal Part-of-Speech tags and morphological properties
# are encoded directly into structural bit positions. All entries use
# the single-notation omi-<8-hex>/<prefix> CIDR format.
#
# Grammar:
#   <omi-address>/<prefix> FACT <assignment-value>

# --- Section 1: Universal Part-of-Speech Hex Indices ---
# Segment[3] — mapped directly via the fourth 16-bit block.
omi-0000-0000-0000-0001-0000-0000-0000-0000/48 FACT universal-pos-NOUN
omi-0000-0000-0000-0002-0000-0000-0000-0000/48 FACT universal-pos-VERB
omi-0000-0000-0000-0003-0000-0000-0000-0000/48 FACT universal-pos-ADJ
omi-0000-0000-0000-0004-0000-0000-0000-0000/48 FACT universal-pos-PRON
omi-0000-0000-0000-0005-0000-0000-0000-0000/48 FACT universal-pos-PROPN
omi-0000-0000-0000-0006-0000-0000-0000-0000/48 FACT universal-pos-ADV
omi-0000-0000-0000-0007-0000-0000-0000-0000/48 FACT universal-pos-ADP
omi-0000-0000-0000-0008-0000-0000-0000-0000/48 FACT universal-pos-CCONJ
omi-0000-0000-0000-0009-0000-0000-0000-0000/48 FACT universal-pos-NUM
omi-0000-0000-0000-000a-0000-0000-0000-0000/48 FACT universal-pos-DET
omi-0000-0000-0000-000b-0000-0000-0000-0000/48 FACT universal-pos-PART
omi-0000-0000-0000-000c-0000-0000-0000-0000/48 FACT universal-pos-SCONJ
omi-0000-0000-0000-000d-0000-0000-0000-0000/48 FACT universal-pos-INTJ
omi-0000-0000-0000-000e-0000-0000-0000-0000/48 FACT universal-pos-PUNCT
omi-0000-0000-0000-000f-0000-0000-0000-0000/48 FACT universal-pos-SYM
omi-0000-0000-0000-0010-0000-0000-0000-0000/48 FACT universal-pos-X
omi-0000-0000-0000-0017-0000-0000-0000-0000/48 FACT universal-pos-AUX

